# Maintainer: twig <fatihbakal7@protonmail.com>

: ${CARGO_HOME:=$SRCDEST/cargo-home}
: ${CARGO_TARGET_DIR:=target}
: ${RUSTUP_TOOLCHAIN:=stable}
export CARGO_HOME CARGO_TARGET_DIR RUSTUP_TOOLCHAIN

pkgname=pvzge-app-git
pkgver=1.8.4.r103.gb2a7a30
pkgrel=1
pkgdesc='Electron packaging for pvz2 ge'
url='https://github.com/Twig6943/PVZGE-Electron'
source=('git+https://github.com/Twig6943/PVZGE-Electron.git')
arch=('any')
license=('GPL-3.0-or-later')
makedepends=('rust' 'meson' 'git' 'perl' 'nasm')
depends=('zerotier-one' 'webkit2gtk' 'libappindicator-gtk3' 'libayatana-appindicator' 'gtk3' 'glib2')
conflicts=('zerotier-desktop-ui')
options=('!lto')
sha256sums=(SKIP)

build () {
  cd PVZGE-Electron
  make official
}

package() {
  cd DesktopUI
  install -Dm755 release/release/pvzge-app "${pkgdir}/usr/bin/pvzge-app"
  install -Dm644 pvzge-app.desktop "${pkgdir}/usr/share/applications/pvzge-app.desktop"
  install -Dm644 pvzge-app.png "${pkgdir}/usr/share/icons/hicolor/512x512/apps/pvzge-app.png"
}

pkgver() {
    cd PVZGE-Electron
    git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}
